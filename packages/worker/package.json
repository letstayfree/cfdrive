{
    "name": "@cfdrive/worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wrangler dev --persist-to ../../.wrangler/state",
        "build": "wrangler deploy --dry-run --outdir=dist",
        "deploy": "wrangler deploy",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db:migrate": "wrangler d1 migrations apply cfdrive-db --local --persist-to ../../.wrangler/state",
        "db:migrate:prod": "wrangler d1 migrations apply cfdrive-db --remote",
        "db:create-migration": "wrangler d1 migrations create cfdrive-db",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "hono": "^4.0.0",
        "nanoid": "^5.0.4"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260131.0",
        "@types/node": "^20.19.30",
        "typescript": "^5.3.3",
        "vitest": "^1.2.0",
        "wrangler": "^3.24.0"
    }
}
